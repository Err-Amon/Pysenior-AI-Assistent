# ============================================
# PySenior Configuration File
# ============================================
# IMPORTANT: Never commit this file to Git!
# This file contains sensitive API keys and secrets.
# ============================================

# ============================================
# GitHub Configuration
# ============================================

# GitHub Personal Access Token
# Get it from: https://github.com/settings/tokens
# Required scopes: repo, write:discussion
# Format: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=your_github_token_here

# GitHub Webhook Secret
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Use this same value when setting up the webhook on GitHub
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here


# ============================================
# Application Configuration
# ============================================

# Environment: development, staging, or production
APP_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR
# Use DEBUG for development, INFO for production
LOG_LEVEL=INFO

# Maximum file size to process (in KB)
# Files larger than this will be skipped
# Default: 500 (500KB)
MAX_FILE_SIZE_KB=500


# ============================================
# LLM / AI Configuration
# ============================================

# LLM Provider to use
# Options: "openai", "anthropic", "gemini", "groq", "openrouter"
# Default: openai
# 
# FREE OPTIONS:
#   - gemini: Google Gemini (1M tokens/day FREE)
#   - groq: Groq (14,400 requests/day FREE, super fast)
#   - openrouter: Access to multiple models with flexible pricing
LLM_PROVIDER=gemini

# --------------------------------------------
# OpenAI Configuration
# --------------------------------------------
# Get your key from: https://platform.openai.com/api-keys
# Cost: ~$0.03 per medium-sized PR review
# Free: $5 credits for new accounts (3 months)
# Format: sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

OPENAI_API_KEY=your_openai_key_here

# --------------------------------------------
# Anthropic Configuration (Alternative)
# --------------------------------------------
# Get your key from: https://console.anthropic.com/settings/keys
# Cost: ~$0.02 per medium-sized PR review
# Free: Sometimes $5 credits for new accounts
# Format: sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

ANTHROPIC_API_KEY=your_anthropic_key_here

# --------------------------------------------
# Google Gemini Configuration (FREE TIER)
# --------------------------------------------
# Get your key from: https://makersuite.google.com/app/apikey
# Cost: 100% FREE for testing (1 million tokens/day)
# No credit card required!
# Format: AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

GEMINI_API_KEY=your_gemini_key_here

# --------------------------------------------
# Groq Configuration (FREE & FAST)
# --------------------------------------------
# Get your key from: https://console.groq.com
# Cost: 100% FREE (14,400 requests/day)
# No credit card required!
# 10x faster than OpenAI!
# Format: gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

GROQ_API_KEY=your_groq_key_here

# --------------------------------------------
# OpenRouter Configuration (FLEXIBLE)
# --------------------------------------------
# Get your key from: https://openrouter.ai/keys
# Cost: Pay-per-use, access to 100+ models
# Free: $1 credit for new accounts
# Models: Claude, GPT-4, Gemini, Llama, and many more
# Format: sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Docs: https://openrouter.ai/docs

OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: Choose which model to use (default: Claude 3.5 Sonnet)
# Popular options:
#   - anthropic/claude-3.5-sonnet (recommended, $3/$15 per 1M tokens)
#   - openai/gpt-4o (good quality, $2.50/$10 per 1M tokens)
#   - google/gemini-pro-1.5 (fast, $1.25/$5 per 1M tokens)
#   - meta-llama/llama-3.1-70b-instruct (FREE on some routes!)
#   - See all models: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet


# ============================================
# Advanced Configuration (Optional)
# ============================================

# Database URL (for future use - Phase 2)
# DATABASE_URL=postgresql://user:password@localhost:5432/pysenior

# Redis URL (for caching - Phase 2)
# REDIS_URL=redis://localhost:6379/0

# Sentry DSN (for error tracking - optional)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Custom API timeout (seconds)
# API_TIMEOUT=60

# Maximum concurrent reviews
# MAX_CONCURRENT_REVIEWS=5


# ============================================
# Quick Setup Instructions
# ============================================
#
# 1. Get GitHub Token:
#    - Go to https://github.com/settings/tokens
#    - Click "Generate new token (classic)"
#    - Select "repo" scope
#    - Copy token and paste above
#
# 2. Generate Webhook Secret:
#    Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
#    Copy output and paste above
#
# 3. Get OpenAI API Key:
#    - Go to https://platform.openai.com/api-keys
#    - Click "Create new secret key"
#    - Copy key and paste above
#    - Add payment method in billing settings
#    - Set usage limit to $10/month
#
# 4. Test Configuration:
#    Run: python -c "from app.config import get_settings; s=get_settings(); print('Config loaded!')"
#
# 5. Start Server:
#    Run: uvicorn app.main:app --reload
#
# ============================================
# Security Reminders
# ============================================
# This file is in .gitignore (never committed)
# Never share this file or its contents
# Rotate keys periodically (every 3-6 months)
# Delete old/unused keys from provider dashboards
# Set spending limits on OpenAI/Anthropic
# Use different keys for dev/staging/production
# ============================================